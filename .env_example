# ── API keys ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TAVILY_API_KEY=

# ── Startup diagnostics ──────────────────────────────────────────────────────
LOG_MODELS=false

# ── LangSmith tracing ────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=self-reflection-agent

# ── Global model fallback (used when no agent/node-specific model is set) ────
MODEL_NAME=nvidia/nemotron-3-nano-30b-a3b:free

# ── self_reflection_agent (v1) models ───────────────────────────────────────
# Agent-wide override (applies to all v1 nodes not individually set):
# REFLECTION_V1_MODEL=

# Per-node overrides:
# REFLECTION_V1_SEARCH_DECISION_MODEL=
# REFLECTION_V1_GENERATE_MODEL=
# REFLECTION_V1_REFLECT_MODEL=

# ── self_reflection_agent_v2 models ─────────────────────────────────────────
# Agent-wide override:
# REFLECTION_V2_MODEL=

# Per-node overrides:
# REFLECTION_V2_GENERATE_MODEL=
# REFLECTION_V2_REFLECT_MODEL=

# ── research_agent models ────────────────────────────────────────────────────
# Agent-wide override:
RESEARCH_MODEL=qwen/qwen3-vl-235b-a22b-thinking

# Per-node overrides:
# RESEARCH_PLANNER_MODEL=
# RESEARCH_FILTER_MODEL=
# RESEARCH_SYNTHESIZER_MODEL=
# RESEARCH_TOPIC_EXTRACTOR_MODEL=
# RESEARCH_KEYWORD_EXPANDER_MODEL=
# RESEARCH_QUERY_GENERATOR_MODEL=

# Embedding model (for semantic similarity filtering in rank_results_by_similarity):
RESEARCH_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ── research_agent date parsing ──────────────────────────────────────────────
DUCKLING_URL=http://localhost:8000
